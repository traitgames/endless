# Copy this file to .env and fill in values for local development.
OPENAI_API_KEY=your_openai_api_key_here
CODEX_MODEL=gpt-5.3-codex
CODEX_ROUTER_MODEL=gpt-5-mini # optional: model for hybrid route classification (Responses API)
PORT=8787
CODEX_BACKEND_MODE=hybrid # repo|hybrid
CODEX_CLI_SANDBOX=workspace-write
CODEX_CLI_FULL_AUTO=1
CODEX_CLI_TIMEOUT_MS=180000
